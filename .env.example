# Copie para .env e ajuste no ambiente local. Nunca versionar .env.
APP_ENV=development
APP_SECRET_KEY=change-this-local-secret
DATABASE_URL=sqlite:///data/basilica_financeiro.sqlite3
# PostgreSQL/rede ainda exigem migracao validada; nao usar em producao nesta fase.
# DATABASE_URL=postgresql://usuario@localhost:5432/basilica
# Homologacao PostgreSQL fica separada do DATABASE_URL operacional.
# Nunca versionar usuario/senha reais neste arquivo.
# O comando administrativo exige alvo descartavel e --confirm-disposable-target.
# Instale psycopg/psycopg2 apenas no ambiente de homologacao descartavel.
POSTGRES_REHEARSAL_DATABASE_URL=
POSTGRES_REHEARSAL_ENABLE_EXECUTION=false
BACKUP_ENCRYPTION_KEY=
BACKUP_AUTO_DAILY=true
SESSION_TIMEOUT_MINUTES=30
LOG_LEVEL=INFO

# Obrigatorio no primeiro boot para criar o primeiro usuario.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=

# Integrações futuras. Não preencher no código.
ASAAS_ENV=sandbox
# Chave local do Asaas. Nunca versionar valor real.
ASAAS_API_KEY=
# Escrita no Asaas permanece desligada por padrao.
ASAAS_ENABLE_WRITE_OPERATIONS=false
PDV_DATABASE_URL=sqlite:///data/pdv.sqlite3
GOOGLE_CLIENT_SECRET_PATH=
GOOGLE_TOKEN_PATH=
